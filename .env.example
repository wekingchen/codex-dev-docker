# 默认跟踪本项目发布的官方 latest 镜像。
CODEX_DEV_IMAGE=ghcr.io/wekingchen/codex-dev-base:latest

# Compose、运行脚本和重置脚本共用同一个实际 Docker volume。
HOME_VOLUME=codex-dev-home

# 相对路径以仓库根目录为基准，也可以填写绝对路径；自定义目录请提前创建。
WORKSPACE=./workspace

# 默认每次启动都检查 GHCR 是否有更新；离线使用时可改为 missing。
CODEX_DEV_PULL_POLICY=always

# 长期运行的key-only SSH镜像；仅由compose.remote.yaml使用。
CODEX_REMOTE_IMAGE=ghcr.io/wekingchen/codex-dev-remote:latest

# 远程SSH端口始终只绑定宿主机127.0.0.1；请通过宿主机SSH ProxyJump进入。
CODEX_REMOTE_PORT=2222

# SSH host key独立于home持久化，更新或重建容器不会改变fingerprint。
CODEX_REMOTE_HOST_KEY_VOLUME=codex-dev-remote-hostkeys
